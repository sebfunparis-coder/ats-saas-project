# ====================================
# 🔧 CONFIGURATION FRONTEND ATS ULTIMATE
# Copier ce fichier en ".env" : cp .env.example .env
# NE JAMAIS commiter .env dans Git !
# ====================================

# URL de l'API backend (OBLIGATOIRE)
# Développement local :
VITE_API_URL=http://localhost:5000/api
# Production :
# VITE_API_URL=https://api.votre-domaine.com/api

# Informations de l'application (optionnel)
VITE_APP_NAME=ATS Ultimate SaaS
VITE_APP_VERSION=1.0.0

# Google Analytics 4 (optionnel — active aussi le reporting Web Vitals vers GA4)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry Error Tracking (optionnel)
# VITE_SENTRY_DSN=https://xxxxx@oxxxxxxxxxxxxxxxx.ingest.sentry.io/xxxxxxx

# Sentry Source Maps Upload (CI/CD uniquement — ne pas mettre dans .env local)
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx
# SENTRY_ORG=votre-org-sentry
# SENTRY_PROJECT=ats-frontend
