# Configuration de l'application
# Copier ce fichier en .env et modifier les valeurs

# Nom de l'application
VITE_APP_NAME=ATS SaaS Platform

# URL de l'API (si vous en avez une)
VITE_API_URL=https://api.votredomaine.com

# Mode de développement
VITE_DEV_MODE=false

# Analytics (optionnel)
VITE_ANALYTICS_ID=

# Support email
VITE_SUPPORT_EMAIL=support@votredomaine.com

# Version
VITE_APP_VERSION=1.0.0
