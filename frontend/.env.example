# ====================================
# CONFIGURATION FRONTEND ATS ULTIMATE
# Copiez ce fichier en .env.local et remplissez vos valeurs
# NE JAMAIS commiter .env.local dans Git
# ====================================

# Application
VITE_APP_NAME=ATS Ultimate
VITE_APP_VERSION=1.0.0

# API Backend
VITE_API_URL=http://localhost:5000/api

# Supabase (si utilisé pour l'auth)
# VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# Sentry Error Tracking (optionnel)
# VITE_SENTRY_DSN=https://xxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SuperAdmin — clé locale (page /admin-login)
# VITE_SUPERADMIN_KEY=CHANGE_ME_strong_local_key

# Demo credentials (dev uniquement — utilisés par le bouton "Essayer la démo")
# VITE_DEMO_EMAIL=demo@techcorp.com
# VITE_DEMO_PASSWORD=CHANGE_ME

# Analytics GA4 (optionnel)
VITE_ANALYTICS_ID=

# Support
VITE_SUPPORT_EMAIL=support@votre-domaine.com
