{
  "name": "ats-saas-platform",
  "version": "1.0.0",
  "description": "Plateforme SaaS ATS - Système de recrutement complet",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "vite preview --port 3000",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,json}\"",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:rls": "node src/__tests__/rls/supabaseRls.test.mjs"
  },
  "keywords": [
    "ats",
    "saas",
    "recrutement",
    "rh"
  ],
  "author": "Votre Nom",
  "license": "MIT",
  "dependencies": {
    "@sentry/react": "^10.62.0",
    "@supabase/supabase-js": "^2.104.0",
    "@tanstack/react-query": "^5.101.2",
    "i18next": "^26.3.1",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^5.5.207",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.13.0",
    "react-window": "^2.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@sentry/vite-plugin": "^5.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "terser": "^5.46.0",
    "vite": "^5.0.8",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,json}": [
      "prettier --write"
    ]
  }
}
