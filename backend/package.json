{
  "name": "ats-ultimate-backend",
  "version": "1.0.0",
  "description": "Backend API pour ATS Ultimate SaaS - Système de recrutement",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --forceExit",
    "lint": "eslint src/",
    "db:migrate": "node src/config/migrate.js",
    "db:seed": "node src/scripts/seed.js",
    "test:connection": "node src/scripts/test-connection.js",
    "migrate:s3": "node src/scripts/migrate-to-s3.js",
    "migrate:s3:delete-local": "node src/scripts/migrate-to-s3.js --delete-local",
    "lint:fix": "eslint src/ --fix",
    "test:coverage": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --forceExit",
    "test:unit": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=\"multitenant|analytics\" --coverage=false --forceExit"
  },
  "keywords": [
    "ats",
    "recruitment",
    "saas",
    "api",
    "nodejs",
    "express"
  ],
  "author": "Votre Nom",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@aws-sdk/client-s3": "^3.1072.0",
    "@aws-sdk/s3-request-presigner": "^3.1072.0",
    "@sentry/node": "^10.58.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "file-type": "^21.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "nodemailer": "^6.9.7",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "stripe": "^22.3.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.9.4",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
