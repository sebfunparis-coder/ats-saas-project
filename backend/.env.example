# ====================================
# 🔧 CONFIGURATION BACKEND ATS ULTIMATE
# Copier ce fichier en ".env" : cp .env.example .env
# NE JAMAIS commiter .env dans Git !
# ====================================

# Environment
NODE_ENV=development

# Server
PORT=5000
FRONTEND_URL=

# Database MongoDB
# Option 1: Local
MONGODB_URI=mongodb://localhost:27017/ats-ultimate
# Option 2: Atlas (Cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ats-ultimate?retryWrites=true&w=majority

# JWT Authentication (minimum 32 caractères — à changer en production !)
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# Email — Choisir UN provider (priorité : Resend > SendGrid > SMTP générique)
# Resend (recommandé) : https://resend.com → API Keys → Create
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SendGrid : https://app.sendgrid.com → Settings → API Keys
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SMTP générique :
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=
# EMAIL_PASS=
EMAIL_FROM=noreply@votre-domaine.com
EMAIL_FROM_NAME=ATS Ultimate
# ⚠️ Configurer DKIM/SPF/DMARC sur votre domaine pour la délivrabilité

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/

# Rate Limiting (toutes optionnelles — valeurs ci-dessous = défauts production)
# Fenêtre globale et auth en millisecondes (défaut: 900000 = 15 min)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=100     # req / 15 min / IP
RATE_LIMIT_AUTH_MAX=5         # tentatives login / 15 min / IP
RATE_LIMIT_API_MAX=60         # req / min / user
RATE_LIMIT_REGISTER_MAX=3     # inscriptions / heure / IP
RATE_LIMIT_RESET_MAX=3        # reset password / heure
RATE_LIMIT_UPLOAD_MAX=10      # uploads / 15 min / user
RATE_LIMIT_SENSITIVE_MAX=5    # opérations sensibles / heure / user
# En NODE_ENV=test, toutes les limites sont désactivées automatiquement (max=100000)

# SuperAdmin Account (créé automatiquement au seed)
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_FIRST_NAME=Super
SUPERADMIN_LAST_NAME=Admin

# Mock DB (développement sans MongoDB — optionnel)
# Si non défini, un mot de passe aléatoire est généré et affiché au démarrage
MOCK_ADMIN_EMAIL=admin@localhost
MOCK_ADMIN_PASSWORD=

# Stripe (optionnel)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxx
# STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxx
# STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxxxxxxxxxx

# Anthropic Claude AI (scoring candidatures)
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Sentry Error Tracking (optionnel)
# SENTRY_DSN=https://xxxxx@oxxxxxxxxxxxxxxxx.ingest.sentry.io/xxxxxxx

# ============================================================
# BLOC 5 — INTÉGRATIONS RÉELLES
# ============================================================

# T-274 — Twilio SMS (convocations, rappels, mises à jour statut)
# Console : console.twilio.com → Account Info
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+33757000000

# T-270 — Google Calendar OAuth2 (sync entretiens)
# Console : console.cloud.google.com → APIs & Services → Credentials
# GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx
# GOOGLE_REDIRECT_URI=https://votre-domaine.com/api/calendar/google/callback

# T-271 — Microsoft Outlook / M365 OAuth2 (sync entretiens)
# Console : portal.azure.com → App Registrations → New Registration
# MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# MICROSOFT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MICROSOFT_TENANT_ID=common
# MICROSOFT_REDIRECT_URI=https://votre-domaine.com/api/calendar/microsoft/callback

# T-272 — Zoom API (création réunions automatique)
# Console : marketplace.zoom.us → Develop → Build App → Server-to-Server OAuth
# ZOOM_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
# ZOOM_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
# ZOOM_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# T-267 — LinkedIn Jobs API (publication offres)
# Nécessite LinkedIn Talent Solutions Partner Program
# linkedin.com/help/linkedin/answer/a543895
# [Tokens OAuth2 stockés en DB — configurables via AdminPage → Intégrations]

# T-268 — Indeed Publisher (publication offres)
# Console : ads.indeed.com → Publisher → API Keys
# [Credentials stockés en DB — configurables via AdminPage → Intégrations]

# T-269 — HelloWork / APEC / Monster (jobboards français)
# HelloWork : partners.hellowork.com
# APEC : apec.fr/partenaires (partenariat institutionnel requis)
# Monster : monster.fr → compte Business
# [Credentials stockés en DB — configurables via AdminPage → Intégrations]

# T-275 — Yousign (signature électronique eIDAS)
# Console : yousign.com → Settings → API Keys
# YOUSIGN_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# YOUSIGN_ENV=sandbox   # ou 'production'
