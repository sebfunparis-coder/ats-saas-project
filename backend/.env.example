# ====================================
# 🔧 CONFIGURATION BACKEND ATS ULTIMATE
# ====================================

# Environment
NODE_ENV=development

# Server
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database MongoDB
# Option 1: MongoDB Local
MONGODB_URI=mongodb://localhost:27017/ats-ultimate

# Option 2: MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ats-ultimate?retryWrites=true&w=majority

# JWT Secret (CHANGEZ-MOI EN PRODUCTION!)
JWT_SECRET=votre-super-secret-jwt-tres-securise-changez-moi-en-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=votre-refresh-token-secret-changez-moi
JWT_REFRESH_EXPIRES_IN=30d

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre.email@gmail.com
EMAIL_PASS=votre-mot-de-passe-app
EMAIL_FROM=noreply@ats-ultimate.com

# File Upload
MAX_FILE_SIZE=5242880
# 5MB en bytes

# Rate Limiting
RATE_LIMIT_WINDOW=15
# en minutes
RATE_LIMIT_MAX_REQUESTS=100

# Admin Default Account (créé automatiquement si n'existe pas)
ADMIN_EMAIL=admin@ats-ultimate.com
ADMIN_PASSWORD=Admin123!ChangezMoi
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=ATS

# ====================================
# 📝 INSTRUCTIONS
# ====================================
# 1. Copier ce fichier en ".env" : cp .env.example .env
# 2. Modifier les valeurs selon votre configuration
# 3. NE JAMAIS commiter le fichier .env dans Git!
# 4. En production, utiliser les variables d'environnement du serveur
